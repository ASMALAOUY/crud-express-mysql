<div class="product-card">
  <div class="card">
    <div class="card-header">
      <h1 class="h3 mb-0">
        <i class="fas fa-plus-circle"></i> Ajouter un produit
      </h1>
    </div>
    <div class="card-body">
      <form action="/products/create" method="POST" class="product-form">
        <div class="form-group">
          <label for="name" class="form-label">
            <i class="fas fa-tag"></i> Nom du produit <span class="text-danger">*</span>
          </label>
          <input type="text" 
                 class="form-control <%= errors && errors.find(e => e.param === 'name') ? 'is-invalid' : '' %>" 
                 id="name" 
                 name="name" 
                 value="<%= product && product.name ? product.name : '' %>" 
                 required 
                 placeholder="Entrez le nom du produit">
          <% if (errors && errors.find(e => e.param === 'name')) { %>
            <div class="invalid-feedback">
              <%= errors.find(e => e.param === 'name').msg %>
            </div>
          <% } %>
        </div>
        
        <div class="form-group">
          <label for="price" class="form-label">
            <i class="fas fa-euro-sign"></i> Prix <span class="text-danger">*</span>
          </label>
          <div class="input-group">
            <input type="number" 
                   class="form-control <%= errors && errors.find(e => e.param === 'price') ? 'is-invalid' : '' %>" 
                   id="price" 
                   name="price" 
                   value="<%= product && product.price ? product.price : '' %>" 
                   step="0.01" 
                   min="0" 
                   required 
                   placeholder="0.00">
            <span class="input-group-text">€</span>
            <% if (errors && errors.find(e => e.param === 'price')) { %>
              <div class="invalid-feedback">
                <%= errors.find(e => e.param === 'price').msg %>
              </div>
            <% } %>
          </div>
        </div>
        
        <div class="form-group">
          <label for="description" class="form-label">
            <i class="fas fa-align-left"></i> Description
          </label>
          <textarea class="form-control" 
                    id="description" 
                    name="description" 
                    rows="5" 
                    placeholder="Décrivez votre produit..."><%= product && product.description ? product.description : '' %></textarea>
          <small class="text-muted">Optionnel - Maximum 1000 caractères</small>
        </div>
        
        <div class="form-group text-center">
          <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-save"></i> Ajouter le produit
          </button>
          <a href="/products" class="btn btn-secondary btn-lg">
            <i class="fas fa-times"></i> Annuler
          </a>
        </div>
      </form>
    </div>
  </div>
</div>