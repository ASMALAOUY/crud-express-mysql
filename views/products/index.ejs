<div class="product-card">
  <div class="card">
    <div class="card-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1 class="h3 mb-0">
          <i class="fas fa-boxes"></i> Liste des produits
        </h1>
        <div class="mt-2 mt-sm-0">
          <span class="badge badge-primary">
            <i class="fas fa-chart-line"></i> Total: <%= pagination.totalItems %> produits
          </span>
        </div>
      </div>
    </div>
    <div class="card-body">
      <!-- Barre de recherche -->
      <div class="search-bar">
        <form action="/products" method="GET" class="search-form">
          <div class="search-input">
            <input type="text" 
                   name="search" 
                   class="form-control" 
                   placeholder="Rechercher un produit..." 
                   value="<%= searchQuery %>">
          </div>
          <div>
            <select name="limit" class="form-control" onchange="this.form.submit()">
              <option value="5" <%= limit == 5 ? 'selected' : '' %>>5 par page</option>
              <option value="10" <%= limit == 10 ? 'selected' : '' %>>10 par page</option>
              <option value="20" <%= limit == 20 ? 'selected' : '' %>>20 par page</option>
              <option value="50" <%= limit == 50 ? 'selected' : '' %>>50 par page</option>
            </select>
          </div>
          <input type="hidden" name="page" value="1">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-search"></i> Rechercher
          </button>
          <% if (searchQuery) { %>
            <a href="/products" class="btn btn-secondary">
              <i class="fas fa-times"></i> Réinitialiser
            </a>
          <% } %>
        </form>
      </div>
      
      <!-- Tableau des produits -->
      <% if (products.length === 0) { %>
        <div class="alert alert-info text-center">
          <i class="fas fa-info-circle"></i> Aucun produit trouvé.
          <br>
          <a href="/products/create" class="btn btn-primary mt-3">
            <i class="fas fa-plus"></i> Ajouter votre premier produit
          </a>
        </div>
      <% } else { %>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Prix</th>
                <th>Date de création</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(product => { %>
                <tr>
                  <td><span class="badge badge-primary">#<%= product.id %></span></td>
                  <td>
                    <strong><%= product.name %></strong>
                    <% if (product.description && product.description.length > 50) { %>
                      <br><small class="text-muted"><%= product.description.substring(0, 50) %>...</small>
                    <% } else if (product.description) { %>
                      <br><small class="text-muted"><%= product.description %></small>
                    <% } %>
                  </td>
                  <td class="price"><%= product.price.toFixed(2) %> €</td>
                  <td><%= new Date(product.created_at).toLocaleDateString('fr-FR') %></td>
                  <td>
                    <div class="btn-group">
                      <a href="/products/<%= product.id %>" class="btn btn-sm btn-info" title="Voir">
                        <i class="fas fa-eye"></i>
                      </a>
                      <a href="/products/edit/<%= product.id %>" class="btn btn-sm btn-warning" title="Modifier">
                        <i class="fas fa-edit"></i>
                      </a>
                      <form action="/products/<%= product.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')">
                        <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        
        <!-- Pagination -->
        <% if (pagination.totalPages > 1) { %>
          <ul class="pagination">
            <% if (pagination.hasPrev) { %>
              <li class="page-item">
                <a class="page-link" href="?page=<%= pagination.page - 1 %><%= searchQuery ? '&search=' + searchQuery : '' %><%= limit ? '&limit=' + limit : '' %>">
                  <i class="fas fa-chevron-left"></i> Précédent
                </a>
              </li>
            <% } %>
            
            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %><%= searchQuery ? '&search=' + searchQuery : '' %><%= limit ? '&limit=' + limit : '' %>">
                  <%= i %>
                </a>
              </li>
            <% } %>
            
            <% if (pagination.hasNext) { %>
              <li class="page-item">
                <a class="page-link" href="?page=<%= pagination.page + 1 %><%= searchQuery ? '&search=' + searchQuery : '' %><%= limit ? '&limit=' + limit : '' %>">
                  Suivant <i class="fas fa-chevron-right"></i>
                </a>
              </li>
            <% } %>
          </ul>
        <% } %>
      <% } %>
    </div>
  </div>
</div>