<div class="product-card">
  <div class="card">
    <div class="card-header">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1 class="h3 mb-0">
          <i class="fas fa-box"></i> <%= product.name %>
        </h1>
        <div class="btn-group mt-2 mt-sm-0">
          <a href="/products/edit/<%= product.id %>" class="btn btn-warning">
            <i class="fas fa-edit"></i> Modifier
          </a>
          <form action="/products/<%= product.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')">
            <button type="submit" class="btn btn-danger">
              <i class="fas fa-trash"></i> Supprimer
            </button>
          </form>
        </div>
      </div>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <div class="product-info">
            <div class="info-group">
              <label class="text-muted">ID du produit</label>
              <p class="h5">#<%= product.id %></p>
            </div>
            
            <div class="info-group mt-3">
              <label class="text-muted">Prix</label>
              <p class="price-large"><%= product.price.toFixed(2) %> €</p>
            </div>
            
            <div class="info-group mt-3">
              <label class="text-muted">Date de création</label>
              <p><i class="fas fa-calendar"></i> <%= new Date(product.created_at).toLocaleString('fr-FR') %></p>
            </div>
          </div>
        </div>
        
        <div class="col-md-6">
          <div class="info-group">
            <label class="text-muted">Description</label>
            <div class="product-description p-3 bg-light rounded">
              <% if (product.description) { %>
                <p><%= product.description %></p>
              <% } else { %>
                <p class="text-muted"><em>Aucune description disponible</em></p>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="card-footer text-center">
      <a href="/products" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Retour à la liste
      </a>
    </div>
  </div>
</div>